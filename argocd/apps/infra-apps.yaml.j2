  source:
    repoURL: https://rancher.github.io/helm-charts
    chart: system-upgrade-controller
    targetRevision: "104.*"
  destination:
    server: https://kubernetes.default.svc
    namespace: cattle-system
  syncPolicy:
    automated:
      prune: true
      selfHeal: true
    syncOptions:
      - CreateNamespace=true
