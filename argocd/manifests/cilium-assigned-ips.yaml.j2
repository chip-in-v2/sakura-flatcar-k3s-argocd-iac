# ---------------------------------------------------------------
# 固定 ClusterIP Service
#
# K8s の ClusterIP 機能を使い、固定IP で Pod サービスにアクセスできるようにする。
# Cilium kube-proxy replacement が ClusterIP のルーティングをすべてのノードで
# BPF で処理するため、クライアント Pod とサーバ Pod が異なるノードでも通信できる。
#
# 固定IP 一覧:
#   greptimedb : 10.43.1.1 (ports: 4000=HTTP API, 4002=MySQL)
#   grafana    : 10.43.1.2 (port:  3000=HTTP)
#   argocd     : 10.43.1.3 (port:  80=HTTP insecure → pod:8080)
#
# 適用対象通信:
#   vector  -> greptimedb (10.43.1.1:4000)
#   grafana -> greptimedb (10.43.1.1:4002 via Datasource)
#   traefik -> grafana    (10.43.1.2:3000 via Ingress)
#   traefik -> argocd     (10.43.1.3:80   via Ingress)
# ---------------------------------------------------------------

# ---------------------------------------------------------------
# greptimedb 固定IP (10.43.1.1:4000 HTTP API, :4002 MySQL)
# ---------------------------------------------------------------
apiVersion: v1
kind: Service
metadata:
  name: greptimedb
  namespace: greptimedb
spec:
  clusterIP: "10.43.1.1"
  ports:
    - name: http
      port: 4000
      targetPort: 4000
      protocol: TCP
    - name: mysql
      port: 4002
      targetPort: 4002
      protocol: TCP
  selector:
    app.kubernetes.io/name: greptimedb-standalone
---
# ---------------------------------------------------------------
# grafana 固定IP (10.43.1.2:3000)
# ---------------------------------------------------------------
apiVersion: v1
kind: Service
metadata:
  name: grafana-fixed
  namespace: observability
spec:
  clusterIP: "10.43.1.2"
  ports:
    - name: http
      port: 3000
      targetPort: 3000
      protocol: TCP
  selector:
    app.kubernetes.io/name: grafana
---
# ---------------------------------------------------------------
# argocd-server 固定IP (10.43.1.3:80 → pod:8080)
# argocd-server は insecure モードで 8080 をリッスン
# ---------------------------------------------------------------
apiVersion: v1
kind: Service
metadata:
  name: argocd-server-fixed
  namespace: argocd
spec:
  clusterIP: "10.43.1.3"
  ports:
    - name: http
      port: 80
      targetPort: 8080
      protocol: TCP
  selector:
    app.kubernetes.io/name: argocd-server
---
# ---------------------------------------------------------------
# grafana Ingress (grafana Helm chart の ingress.enabled=false に対応)
# ---------------------------------------------------------------
apiVersion: networking.k8s.io/v1
kind: Ingress
metadata:
  name: grafana
  namespace: observability
  annotations:
    traefik.ingress.kubernetes.io/router.tls: "true"
spec:
  ingressClassName: traefik
  tls:
    - hosts:
        - "grafana.{{ domain }}"
  rules:
    - host: "grafana.{{ domain }}"
      http:
        paths:
          - path: /
            pathType: Prefix
            backend:
              service:
                name: grafana-fixed
                port:
                  number: 3000
